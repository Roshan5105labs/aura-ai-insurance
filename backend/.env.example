# ─── Aura Backend — Environment Variables ───────────────────
# Copy this file to .env and fill in your values

# PostgreSQL connection string
# Format: postgresql+asyncpg://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=postgresql+asyncpg://aura_user:aura_pass@localhost:5432/aura_db

# OpenWeather API key (leave as mock_key to use built-in mock data)
OPENWEATHER_API_KEY=mock_key

# Razorpay test keys (mock values work for demo)
RAZORPAY_KEY_ID=rzp_test_mock
RAZORPAY_KEY_SECRET=mock_secret
